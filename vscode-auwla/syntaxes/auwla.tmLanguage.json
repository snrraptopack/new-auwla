{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Auwla",
    "scopeName": "source.auwla",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#decorators"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#storage"
        },
        {
            "include": "#control"
        },
        {
            "include": "#constants"
        },
        {
            "include": "#builtins"
        },
        {
            "include": "#types"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.auwla",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.auwla",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "storage": {
            "patterns": [
                {
                    "comment": "Variable/function declarations — purple in most themes",
                    "name": "storage.type.auwla",
                    "match": "\\b(let|var|fn)\\b"
                },
                {
                    "comment": "Type definitions — teal/green in most themes",
                    "name": "storage.type.class.auwla",
                    "match": "\\b(struct|enum)\\b"
                }
            ]
        },
        "control": {
            "patterns": [
                {
                    "comment": "Control flow keywords — magenta/pink in most themes",
                    "name": "keyword.control.auwla",
                    "match": "\\b(if|else|while|for|in|return|match|break|continue)\\b"
                },
                {
                    "comment": "Module keywords",
                    "name": "keyword.control.import.auwla",
                    "match": "\\b(import|export|from)\\b"
                },
                {
                    "comment": "Extension and type alias keywords",
                    "name": "keyword.other.auwla",
                    "match": "\\b(extend|type)\\b"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "comment": "Boolean and optional literals — orange in most themes",
                    "name": "constant.language.auwla",
                    "match": "\\b(true|false|none|some)\\b"
                },
                {
                    "name": "variable.language.self.auwla",
                    "match": "\\bself\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "comment": "Built-in functions — distinct from user functions",
                    "name": "support.function.auwla",
                    "match": "\\b(print)\\b(?=\\s*\\()"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.auwla",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.auwla",
                    "match": "\\\\."
                },
                {
                    "name": "variable.interpolation.auwla",
                    "begin": "\\{",
                    "end": "\\}",
                    "patterns": [
                        {
                            "include": "$self"
                        }
                    ]
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "comment": "Function definition name",
                    "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
                    "captures": {
                        "1": {
                            "name": "storage.type.auwla"
                        },
                        "2": {
                            "name": "entity.name.function.auwla"
                        }
                    }
                },
                {
                    "comment": "Method call on property: .method_name()",
                    "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.auwla"
                        }
                    }
                },
                {
                    "comment": "Standalone function call: name()",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "name": "entity.name.function.auwla"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.logical.auwla",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.comparison.auwla",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.assignment.auwla",
                    "match": "="
                },
                {
                    "name": "keyword.operator.arithmetic.auwla",
                    "match": "\\+|\\-|\\*|/"
                },
                {
                    "name": "keyword.operator.arrow.auwla",
                    "match": "=>"
                },
                {
                    "comment": "Property access after dot (not a method call)",
                    "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s*\\()",
                    "captures": {
                        "1": {
                            "name": "variable.other.property.auwla"
                        }
                    }
                },
                {
                    "name": "keyword.operator.range.auwla",
                    "match": "\\.\\.<|\\.\\."
                },
                {
                    "name": "punctuation.accessor.auwla",
                    "match": "\\."
                },
                {
                    "name": "punctuation.terminator.auwla",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.auwla",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.auwla",
                    "match": ":"
                },
                {
                    "name": "keyword.operator.optional.auwla",
                    "match": "\\?"
                }
            ]
        },
        "decorators": {
            "patterns": [
                {
                    "comment": "Attribute decorator — gold/yellow in most themes",
                    "name": "entity.name.function.decorator.auwla",
                    "match": "@[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "comment": "Decorator arguments in parentheses",
                    "begin": "(@[a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
                    "beginCaptures": {
                        "1": {
                            "name": "entity.name.function.decorator.auwla"
                        }
                    },
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#strings"
                        },
                        {
                            "name": "punctuation.separator.auwla",
                            "match": ","
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "name": "constant.numeric.auwla",
            "match": "\\b\\d+(\\.\\d+)?\\b"
        },
        "types": {
            "patterns": [
                {
                    "comment": "Built-in primitive types — blue/cyan in most themes",
                    "name": "support.type.auwla",
                    "match": "\\b(number|string|bool|void|char|array)\\b"
                },
                {
                    "comment": "User-defined types (PascalCase) — green/teal in most themes",
                    "name": "entity.name.type.auwla",
                    "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
                }
            ]
        }
    }
}